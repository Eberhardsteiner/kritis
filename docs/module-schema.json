              },
              "name": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "sectorCategory": {
                "type": "string"
              },
              "domainWeightAdjustments": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
