{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/krisenfest-module-schema-v1.json",
  "title": "Krisenfestigkeit Branchenmodul",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "name",
    "version",
    "description"
  ],
  "properties": {
    "schemaVersion": {
      "type": "number",
      "const": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "sectorCategory": {
      "type": "string"
    },
    "domainWeightAdjustments": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "governance": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "operations": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "people": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "physical": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "cyber": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "supply": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "finance": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "bcm": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "uiHints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "accentLabel": {
          "type": "string"
        },
        "focusAreas": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "additionalQuestions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/question"
      }
    },
    "recommendedActions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/actionTemplate"
      }
    },
    "evidenceTemplates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidenceTemplate"
      }
    },
    "kritisExtension": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "eligibleSectors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "hints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "additionalRequirements": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/requirement"
          }
        }
      }
    },
    "roleTemplates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/roleTemplate"
      }
    },
    "maturityProfile": {
      "$ref": "#/$defs/maturityProfile"
    },
    "auditChecklist": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/auditChecklistItem"
      }
    }
  },
  "$defs": {
    "question": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "domainId",
        "title",
        "prompt",
        "guidance",
        "recommendation",
        "weight"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "domainId": {
          "type": "string",
          "enum": [
            "governance",
            "operations",
            "people",
            "physical",
            "cyber",
            "supply",
            "finance",
            "bcm"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "guidance": {
          "type": "string",
          "minLength": 1
        },
        "recommendation": {
          "type": "string",
          "minLength": 1
        },
        "weight": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "critical": {
          "type": "boolean"
        },
        "evidenceHint": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "lawRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "description",
        "guidance"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "guidance": {
          "type": "string",
          "minLength": 1
        },
        "lawRef": {
          "type": "string"
        },
        "dueHint": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        }
      }
    },
    "actionTemplate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "description"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "priority": {
          "type": "string",
          "enum": [
            "kritisch",
            "hoch",
            "mittel",
            "niedrig"
          ]
        },
        "ownerRole": {
          "type": "string"
        },
        "relatedQuestionIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "relatedRequirementIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "evidenceTemplate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "type"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "policy",
            "plan",
            "report",
            "test",
            "training",
            "contract",
            "backup",
            "other"
          ]
        },
        "ownerRole": {
          "type": "string"
        },
        "reviewCycleHint": {
          "type": "string"
        },
        "relatedQuestionIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "relatedRequirementIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "roleTemplate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "responsibility"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "responsibility": {
          "type": "string",
          "minLength": 1
        },
        "approvalScope": {
          "type": "string"
        },
        "focusAreas": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "maturityProfile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "targetOverall": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "targetByDomain": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "governance": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "operations": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "people": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "physical": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "cyber": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "supply": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "finance": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "bcm": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            }
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "auditChecklistItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "area",
        "title",
        "guidance"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "area": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "guidance": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "relatedQuestionIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "relatedRequirementIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
