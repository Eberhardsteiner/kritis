{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/krisenfest-branch-container-schema-v1.json",
  "title": "Krisenfest Branchen-Container",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "containerVersion",
    "manifest",
    "module"
  ],
  "properties": {
    "containerVersion": {
      "type": "number",
      "const": 1
    },
    "targetModuleId": {
      "type": "string",
      "minLength": 1
    },
    "manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packId",
        "packType",
        "moduleId",
        "name",
        "version",
        "description"
      ],
      "properties": {
        "packId": {
          "type": "string",
          "minLength": 1
        },
        "packType": {
          "type": "string",
          "enum": [
            "module",
            "overlay"
          ]
        },
        "moduleId": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "engine": {
          "type": "string"
        },
        "engineVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "sectorCategory": {
          "type": "string"
        },
        "industryClass": {
          "type": "string"
        },
        "maintainer": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "assessment",
              "actions",
              "evidence",
              "governance",
              "kritis",
              "bia",
              "documents",
              "reporting"
            ]
          }
        },
        "compatibility": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "minAppVersion": {
              "type": "string",
              "pattern": "^\\d+\\.\\d+\\.\\d+$"
            },
            "minEngineVersion": {
              "type": "string",
              "pattern": "^\\d+\\.\\d+\\.\\d+$"
            }
          }
        },
        "releaseChannel": {
          "type": "string",
          "enum": [
            "core",
            "sector",
            "overlay",
            "custom"
          ]
        }
      }
    },
    "module": {}
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "manifest": {
            "properties": {
              "packType": {
                "const": "module"
              }
            },
            "required": [
              "packType"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "module": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "https://example.local/krisenfest-module-schema-v1.json",
            "title": "Krisenfestigkeit Branchenmodul",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "schemaVersion",
              "id",
              "name",
              "version",
              "description"
            ],
            "properties": {
              "schemaVersion": {
                "type": "number",
                "const": 1
              },
              "id": {
                "type": "string",
                "minLength": 1
              },
              "name": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": "string",
                "minLength": 1
              },
              "sectorCategory": {
                "type": "string"
              },
              "domainWeightAdjustments": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "governance": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  },
                  "operations": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  },
                  "people": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  },
                  "physical": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  },
                  "cyber": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  },
                  "supply": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  },
                  "finance": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  },
                  "bcm": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  }
                }
              },
              "uiHints": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "accentLabel": {
                    "type": "string"
                  },
                  "focusAreas": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              },
              "additionalQuestions": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/question"
                }
              },
              "recommendedActions": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/actionTemplate"
                }
              },
              "evidenceTemplates": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/evidenceTemplate"
                }
              },
              "kritisExtension": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "eligibleSectors": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "hints": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "additionalRequirements": {
                    "type": "array",
                    "items": {
                      "$ref": "#/$defs/requirement"
                    }
                  }
                }
              },
              "roleTemplates": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/roleTemplate"
                }
              },
              "maturityProfile": {
                "$ref": "#/$defs/maturityProfile"
              },
              "auditChecklist": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/auditChecklistItem"
                }
              },
              "processTemplates": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/processTemplate"
                }
              },
              "dependencyTemplates": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/dependencyTemplate"
                }
              },
              "scenarioTemplates": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/scenarioTemplate"
                }
              },
              "exerciseTemplates": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/exerciseTemplate"
                }
              },
              "documentFolders": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "riskCatalogTemplates": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/riskCatalogTemplate"
                }
              },
              "resiliencePlanTemplate": {
                "$ref": "#/$defs/resiliencePlanTemplate"
              },
              "tabletopScenarios": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/tabletopScenario"
                }
              }
            },
            "$defs": {
              "question": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "id",
                  "domainId",
                  "title",
                  "prompt",
                  "guidance",
                  "recommendation",
                  "weight"
                ],
                "properties": {
                  "id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "domainId": {
                    "type": "string",
                    "enum": [
                      "governance",
                      "operations",
                      "people",
                      "physical",
                      "cyber",
                      "supply",
                      "finance",
                      "bcm"
                    ]
                  },
                  "title": {
                    "type": "string",
                    "minLength": 1
                  },
                  "prompt": {
                    "type": "string",
                    "minLength": 1
                  },
                  "guidance": {
                    "type": "string",
                    "minLength": 1
                  },
                  "recommendation": {
                    "type": "string",
                    "minLength": 1
                  },
                  "weight": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  },
                  "critical": {
                    "type": "boolean"
                  },
                  "evidenceHint": {
                    "type": "string"
                  },
                  "tags": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "lawRefs": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              },
              "requirement": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "id",
                  "title",
                  "description",
                  "guidance"
                ],
                "properties": {
                  "id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "title": {
                    "type": "string",
                    "minLength": 1
                  },
                  "description": {
                    "type": "string",
                    "minLength": 1
                  },
                  "guidance": {
                    "type": "string",
                    "minLength": 1
                  },
                  "lawRef": {
                    "type": "string"
                  },
                  "dueHint": {
                    "type": "string"
                  },
                  "severity": {
                    "type": "string",
                    "enum": [
                      "high",
                      "medium",
                      "low"
                    ]
                  }
                }
              },
              "actionTemplate": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "id",
                  "title",
                  "description"
                ],
                "properties": {
                  "id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "title": {
                    "type": "string",
                    "minLength": 1
                  },
                  "description": {
                    "type": "string",
                    "minLength": 1
                  },
                  "priority": {
                    "type": "string",
                    "enum": [
                      "kritisch",
                      "hoch",
                      "mittel",
                      "niedrig"
                    ]
                  },
                  "ownerRole": {
                    "type": "string"
                  },
                  "relatedQuestionIds": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "relatedRequirementIds": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              },
              "evidenceTemplate": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "id",
                  "title",
                  "type"
                ],
                "properties": {
                  "id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "title": {
                    "type": "string",
                    "minLength": 1
                  },
                  "type": {
                    "type": "string",
                    "enum": [
                      "policy",
                      "plan",
                      "report",
                      "test",
                      "training",
                      "contract",
                      "backup",
                      "other"
                    ]
                  },
                  "ownerRole": {
                    "type": "string"
                  },
                  "reviewCycleHint": {
                    "type": "string"
                  },
                  "relatedQuestionIds": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "relatedRequirementIds": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "folder": {
                    "type": "string"
                  },
                  "tags": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              },
              "roleTemplate": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "id",
                  "label",
                  "responsibility"
                ],
                "properties": {
                  "id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "label": {
                    "type": "string",
                    "minLength": 1
                  },
                  "responsibility": {
                    "type": "string",
                    "minLength": 1
                  },
                  "approvalScope": {
                    "type": "string"
                  },
                  "focusAreas": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              },
              "maturityProfile": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "targetOverall": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 100
                  },
                  "targetByDomain": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "governance": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 100
                      },
                      "operations": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 100
                      },
                      "people": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 100
                      },
                      "physical": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 100
                      },
                      "cyber": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 100
                      },
                      "supply": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 100
                      },
                      "finance": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 100
                      },
                      "bcm": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 100
                      }
                    }
                  },
                  "notes": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              },
              "auditChecklistItem": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "id",
                  "area",
                  "title",
                  "guidance"
                ],
                "properties": {
                  "id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "area": {
                    "type": "string",
                    "minLength": 1
                  },
                  "title": {
                    "type": "string",
                    "minLength": 1
                  },
                  "guidance": {
                    "type": "string",
                    "minLength": 1
                  },
                  "severity": {
                    "type": "string",
                    "enum": [
                      "high",
                      "medium",
                      "low"
                    ]
                  },
                  "relatedQuestionIds": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "relatedRequirementIds": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              },
              "processTemplate": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "id",
                  "title"
                ],
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "title": {
                    "type": "string"
                  },
                  "ownerRole": {
                    "type": "string"
                  },
                  "criticality": {
                    "type": "string",
                    "enum": [
                      "kritisch",
                      "hoch",
                      "mittel",
                      "niedrig"
                    ]
                  },
                  "mtpdHours": {
                    "type": "string"
                  },
                  "rtoHours": {
                    "type": "string"
                  },
                  "rpoHours": {
                    "type": "string"
                  },
                  "dependencies": {
                    "type": "string"
                  },
                  "outputs": {
                    "type": "string"
                  },
                  "notes": {
                    "type": "string"
                  }
                }
              },
              "dependencyTemplate": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "id",
                  "title",
                  "category"
                ],
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "title": {
                    "type": "string"
                  },
                  "category": {
                    "type": "string",
                    "enum": [
                      "lieferant",
                      "it",
                      "ot",
                      "personal",
                      "energie",
                      "logistik",
                      "kommunikation",
                      "gebäude",
                      "dienstleister"
                    ]
                  },
                  "criticality": {
                    "type": "string",
                    "enum": [
                      "kritisch",
                      "hoch",
                      "mittel",
                      "niedrig"
                    ]
                  },
                  "singlePointOfFailure": {
                    "type": "boolean"
                  },
                  "fallback": {
                    "type": "string"
                  },
                  "contractReference": {
                    "type": "string"
                  },
                  "notes": {
                    "type": "string"
                  }
                }
              },
              "scenarioTemplate": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "id",
                  "title",
                  "category",
                  "description"
                ],
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "title": {
                    "type": "string"
                  },
                  "category": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "likelihood": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 5
                  },
                  "impact": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 5
                  },
                  "ownerRole": {
                    "type": "string"
                  },
                  "linkedProcessTemplateIds": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "linkedDependencyTemplateIds": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "playbook": {
                    "type": "string"
                  },
                  "exerciseTypeHint": {
                    "type": "string",
                    "enum": [
                      "tabletop",
                      "simulation",
                      "technical",
                      "alarm",
                      "supplier"
                    ]
                  },
                  "notes": {
                    "type": "string"
                  }
                }
              },
              "exerciseTemplate": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "id",
                  "title"
                ],
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "title": {
                    "type": "string"
                  },
                  "exerciseType": {
                    "type": "string",
                    "enum": [
                      "tabletop",
                      "simulation",
                      "technical",
                      "alarm",
                      "supplier"
                    ]
                  },
                  "scenarioTemplateId": {
                    "type": "string"
                  },
                  "ownerRole": {
                    "type": "string"
                  },
                  "cadenceMonths": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "notes": {
                    "type": "string"
                  }
                }
              },
              "riskCatalogTemplate": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "id",
                  "categoryId",
                  "subCategoryId",
                  "titel",
                  "eintrittswahrscheinlichkeit",
                  "auswirkung",
                  "residualRisk"
                ],
                "properties": {
                  "id": { "type": "string", "minLength": 1 },
                  "categoryId": {
                    "type": "string",
                    "enum": [
                      "nature",
                      "technical",
                      "human_intentional",
                      "human_unintentional",
                      "interdependency",
                      "cyber_physical"
                    ]
                  },
                  "subCategoryId": { "type": "string", "minLength": 1 },
                  "titel": { "type": "string", "minLength": 1 },
                  "beschreibung": { "type": "string" },
                  "eintrittswahrscheinlichkeit": { "type": "integer", "minimum": 1, "maximum": 5 },
                  "auswirkung": { "type": "integer", "minimum": 1, "maximum": 5 },
                  "residualRisk": { "type": "integer", "minimum": 1, "maximum": 5 },
                  "reviewDate": { "type": "string" },
                  "owner": { "type": "string" },
                  "affectedAssetIds": { "type": "array", "items": { "type": "string" } },
                  "affectedProcessIds": { "type": "array", "items": { "type": "string" } },
                  "affectedInterdependencies": { "type": "array", "items": { "type": "string" } },
                  "mitigationMeasureIds": { "type": "array", "items": { "type": "string" } }
                }
              },
              "resiliencePlanTemplate": {
                "type": "object",
                "additionalProperties": false,
                "required": ["content"],
                "properties": {
                  "templateId": { "type": "string", "minLength": 1 },
                  "templateNote": { "type": "string" },
                  "content": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "scope",
                      "riskBasis",
                      "measuresByGoal",
                      "governance",
                      "reporting",
                      "evidence"
                    ],
                    "properties": {
                      "scope": { "$ref": "#/$defs/resilienceScopeSection" },
                      "riskBasis": { "$ref": "#/$defs/resilienceRiskBasisSection" },
                      "measuresByGoal": { "$ref": "#/$defs/resilienceMeasuresByGoal" },
                      "governance": { "$ref": "#/$defs/resilienceGovernanceSection" },
                      "reporting": { "$ref": "#/$defs/resilienceReportingSection" },
                      "evidence": { "$ref": "#/$defs/resilienceEvidenceSection" }
                    }
                  }
                }
              },
              "resilienceScopeSection": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "operatorName": { "type": "string" },
                  "sector": { "type": "string" },
                  "criticalService": { "type": "string" },
                  "locations": { "type": "string" },
                  "employees": { "type": "string" },
                  "personsServed": { "type": "string" },
                  "scopeNote": { "type": "string" }
                }
              },
              "resilienceRiskBasisSection": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "methodology": { "type": "string" },
                  "riskAnalysisReference": { "type": "string" },
                  "topRisks": {
                    "type": "array",
                    "items": { "$ref": "#/$defs/resilienceTopRisk" }
                  },
                  "riskBasisNote": { "type": "string" }
                }
              },
              "resilienceTopRisk": {
                "type": "object",
                "additionalProperties": false,
                "required": ["title", "category", "initialScore", "residualScore", "criticality"],
                "properties": {
                  "riskId": { "type": "string" },
                  "title": { "type": "string" },
                  "category": { "type": "string" },
                  "initialScore": { "type": "number" },
                  "residualScore": { "type": "number" },
                  "criticality": { "type": "string" }
                }
              },
              "resilienceMeasuresByGoal": {
                "type": "object",
                "additionalProperties": false,
                "required": ["prevent", "protect", "respond", "recover"],
                "properties": {
                  "prevent": {
                    "type": "array",
                    "items": { "$ref": "#/$defs/resilienceMeasureReference" }
                  },
                  "protect": {
                    "type": "array",
                    "items": { "$ref": "#/$defs/resilienceMeasureReference" }
                  },
                  "respond": {
                    "type": "array",
                    "items": { "$ref": "#/$defs/resilienceMeasureReference" }
                  },
                  "recover": {
                    "type": "array",
                    "items": { "$ref": "#/$defs/resilienceMeasureReference" }
                  }
                }
              },
              "resilienceMeasureReference": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "title", "description", "goal", "owner", "dueDate", "status"],
                "properties": {
                  "id": { "type": "string", "minLength": 1 },
                  "title": { "type": "string" },
                  "description": { "type": "string" },
                  "goal": {
                    "type": "string",
                    "enum": ["prevent", "protect", "respond", "recover"]
                  },
                  "linkedActionItemId": { "type": "string" },
                  "owner": { "type": "string" },
                  "dueDate": { "type": "string" },
                  "status": {
                    "type": "string",
                    "enum": ["planned", "active", "ready"]
                  }
                }
              },
              "resilienceGovernanceSection": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "managementBoardContact": { "type": "string" },
                  "programOwner": { "type": "string" },
                  "escalationPath": { "type": "string" },
                  "boardReviewCadence": { "type": "string" },
                  "governanceNote": { "type": "string" }
                }
              },
              "resilienceReportingSection": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "incidentContact": { "type": "string" },
                  "incidentBackupContact": { "type": "string" },
                  "bsiPortalNote": { "type": "string" },
                  "firstReportingTimeline": { "type": "string" },
                  "reportingNote": { "type": "string" }
                }
              },
              "resilienceEvidenceSection": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "evidenceReferences": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["title", "type"],
                      "properties": {
                        "title": { "type": "string" },
                        "type": { "type": "string" },
                        "sourceStandard": { "type": "string" }
                      }
                    }
                  },
                  "reviewCycleYears": { "type": "integer", "minimum": 1 },
                  "equivalentProofsNote": { "type": "string" },
                  "evidenceNote": { "type": "string" }
                }
              },
              "tabletopScenario": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "id",
                  "version",
                  "title",
                  "summary",
                  "sectors",
                  "applicableRegimes",
                  "durationMinutes",
                  "roles",
                  "timeline",
                  "evaluationCriteria"
                ],
                "properties": {
                  "id": { "type": "string", "minLength": 1 },
                  "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
                  "title": { "type": "string", "minLength": 1 },
                  "summary": { "type": "string" },
                  "sectors": { "type": "array", "items": { "type": "string" } },
                  "applicableRegimes": { "type": "array", "items": { "type": "string" } },
                  "durationMinutes": { "type": "integer", "minimum": 1 },
                  "roles": {
                    "type": "array",
                    "items": { "$ref": "#/$defs/tabletopExerciseRole" }
                  },
                  "timeline": {
                    "type": "array",
                    "items": { "$ref": "#/$defs/tabletopTimelineStep" }
                  },
                  "evaluationCriteria": {
                    "type": "array",
                    "items": { "$ref": "#/$defs/tabletopEvaluationCriterion" }
                  }
                }
              },
              "tabletopExerciseRole": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "title", "briefing"],
                "properties": {
                  "id": { "type": "string", "minLength": 1 },
                  "title": { "type": "string" },
                  "briefing": { "type": "string" }
                }
              },
              "tabletopTimelineStep": {
                "type": "object",
                "additionalProperties": false,
                "required": ["t", "phase", "injects", "decisions"],
                "properties": {
                  "t": { "type": "number" },
                  "phase": {
                    "type": "string",
                    "enum": [
                      "discovery",
                      "early_response",
                      "24h_reporting",
                      "stabilization",
                      "recovery"
                    ]
                  },
                  "injects": {
                    "type": "array",
                    "items": { "$ref": "#/$defs/tabletopTimelineInject" }
                  },
                  "decisions": {
                    "type": "array",
                    "items": { "$ref": "#/$defs/tabletopTimelineDecision" }
                  }
                }
              },
              "tabletopTimelineInject": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "title", "description"],
                "properties": {
                  "id": { "type": "string", "minLength": 1 },
                  "title": { "type": "string" },
                  "description": { "type": "string" },
                  "roleId": { "type": "string" }
                }
              },
              "tabletopTimelineDecision": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "question", "options"],
                "properties": {
                  "id": { "type": "string", "minLength": 1 },
                  "question": { "type": "string" },
                  "options": {
                    "type": "array",
                    "items": { "$ref": "#/$defs/tabletopTimelineDecisionOption" }
                  },
                  "roleId": { "type": "string" },
                  "relatedCriteria": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "guidance": { "type": "string" }
                }
              },
              "tabletopTimelineDecisionOption": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "label"],
                "properties": {
                  "id": { "type": "string", "minLength": 1 },
                  "label": { "type": "string" },
                  "consequence": { "type": "string" },
                  "evaluationHints": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "scoreContribution": { "type": "number" }
                }
              },
              "tabletopEvaluationCriterion": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "description", "weight"],
                "properties": {
                  "id": { "type": "string", "minLength": 1 },
                  "description": { "type": "string" },
                  "weight": { "type": "number" },
                  "category": {
                    "type": "string",
                    "enum": [
                      "reporting",
                      "governance",
                      "operations",
                      "communication",
                      "other"
                    ]
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "manifest": {
            "properties": {
              "packType": {
                "const": "overlay"
              }
