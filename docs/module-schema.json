                }
              },
              "evidenceTemplates": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/evidenceTemplate"
                }
              },
              "documentFolders": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "roleTemplates": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/roleTemplate"
                }
              },
              "maturityProfile": {
                "$ref": "#/$defs/maturityProfile"
              },
              "auditChecklist": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/auditChecklistItem"
                }
              },
              "processTemplates": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/processTemplate"
                }
