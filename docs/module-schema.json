                  },
                  "people": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  },
                  "physical": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  },
                  "cyber": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  },
                  "supply": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  },
                  "finance": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  },
                  "bcm": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  }
                }
              },
              "additionalQuestions": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/question"
                }
              },
              "recommendedActions": {
                "type": "array",
                "items": {
