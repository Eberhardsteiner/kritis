                }
              },
              "resiliencePlanTemplate": {
                "$ref": "#/$defs/resiliencePlanTemplate"
              },
              "tabletopScenarios": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/tabletopScenario"
                }
              },
              "uiHints": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "accentLabel": {
                    "type": "string"
                  },
                  "focusAreas": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
