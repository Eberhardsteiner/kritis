{
  "name": "krisenfest-app-produktpaket-p3",
  "private": true,
  "version": "2.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,app -c auto \"node server/index.js\" \"vite --host 0.0.0.0\"",
    "typecheck": "tsc -b",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "npm run test:server",
    "test:server": "node --test server/security.test.js server/persistence.test.js server/module-packs.test.js server/regulatory-dach.test.js server/hardening.test.js server/auth-provider.test.js server/object-storage.test.js server/evidence-platform.test.js"
  },
  "dependencies": {
    "concurrently": "9.0.1",
    "express": "4.21.2",
    "jspdf": "4.2.1",
    "lucide-react": "0.511.0",
    "multer": "2.1.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "helmet": "8.1.0"
  },
  "devDependencies": {
    "@types/express": "5.0.1",
    "@types/multer": "1.4.12",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@vitejs/plugin-react": "4.3.1",
    "typescript": "5.5.4",
    "vite": "5.4.21"
  },
  "stackblitz": {
    "startCommand": "npm run dev",
    "installDependencies": true
  }
}
